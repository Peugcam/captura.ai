# GTA Analytics V2 - Environment Variables Template

# OpenAI API
OPENAI_API_KEY=sk-...

# OpenRouter API (Opcional - Alternativa mais barata)
OPENROUTER_API_KEY=sk-or-...

# Vision API Configuration
VISION_MODEL=gpt-4o
VISION_PRE_FILTER=true

# Frame Processing
USE_ROI=false
OCR_PRE_FILTER=false

# Ports (Cloud)
PORT=8080
GATEWAY_PORT=8000
BACKEND_PORT=3000
