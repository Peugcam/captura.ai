# ============================================================
# GTA Analytics V2 - Backend Configuration
# ============================================================
# Copy this file to .env and fill in your values

# ------------------------------------------------------------
# Gateway Connection
# ------------------------------------------------------------
GATEWAY_URL=http://localhost:8000
GATEWAY_IPC_MODE=auto  # auto, unix, pipe, http (auto detects best option)
POLL_INTERVAL=1.0  # seconds
FRAMES_BATCH_SIZE=10

# ------------------------------------------------------------
# Game Configuration
# ------------------------------------------------------------
GAME_TYPE=gta  # gta or naruto
USE_ROI=true  # Enable Region of Interest (top-right 25% for GTA)
ROI_X=0.75  # X coordinate (0.75 = 75% from left)
ROI_Y=0
ROI_WIDTH=0.25
ROI_HEIGHT=0.35

# ------------------------------------------------------------
# OCR Pre-Filter
# ------------------------------------------------------------
OCR_ENABLED=true
OCR_WORKERS=4  # Parallel OCR workers

# ------------------------------------------------------------
# Vision AI - LiteLLM Configuration
# ------------------------------------------------------------
USE_LITELLM=false  # Use LiteLLM for multi-model support with fallback
LITELLM_ENABLE_FALLBACK=true  # Enable automatic fallback on errors

# API Keys (fallback chain: Together → SiliconFlow → OpenRouter → OpenAI)
# At least ONE key is required

# Together AI (Llama 3.2 Vision - Fastest, cheapest)
# Get key from: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=

# SiliconFlow (Qwen2-VL - Good quality, low cost)
# Get key from: https://cloud.siliconflow.cn/account/ak
SILICONFLOW_API_KEY=

# OpenRouter (GPT-4o via OpenRouter - Multiple models available)
# Get key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# OpenAI (GPT-4o Direct - Highest quality, last resort)
# Get key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Legacy API Keys Support (for backward compatibility)
# If USE_LITELLM=false, these are used directly
API_KEYS=  # Comma-separated OpenRouter keys
VISION_MODEL=openai/gpt-4o

# ------------------------------------------------------------
# Vision API Batch Processing
# ------------------------------------------------------------
BATCH_SIZE_QUICK=10  # Frames per quick batch
BATCH_SIZE_DEEP=15  # Frames per deep analysis
QUICK_BATCH_INTERVAL=2.0  # seconds
DEEP_BATCH_INTERVAL=60.0  # seconds

# ------------------------------------------------------------
# Advanced Features
# ------------------------------------------------------------
USE_ADVANCED_PROMPT=false  # Use advanced GTA Battle Royale prompt

# ------------------------------------------------------------
# Backend Server
# ------------------------------------------------------------
BACKEND_PORT=3000
BACKEND_HOST=0.0.0.0

# ------------------------------------------------------------
# Export
# ------------------------------------------------------------
EXPORT_DIR=./exports

# ------------------------------------------------------------
# Logging
# ------------------------------------------------------------
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR

# ============================================================
# Example Configurations
# ============================================================

# Minimal Configuration (OpenAI only):
# OPENAI_API_KEY=sk-proj-xxxxx
# USE_LITELLM=false

# Cost-Optimized (Together AI primary):
# TOGETHER_API_KEY=xxxxx
# OPENROUTER_API_KEY=sk-or-v1-xxxxx  # fallback
# USE_LITELLM=true

# Maximum Resilience (all providers):
# TOGETHER_API_KEY=xxxxx
# SILICONFLOW_API_KEY=xxxxx
# OPENROUTER_API_KEY=sk-or-v1-xxxxx
# OPENAI_API_KEY=sk-proj-xxxxx
# USE_LITELLM=true
# LITELLM_ENABLE_FALLBACK=true

# Cloud Deployment (Fly.io):
# GATEWAY_URL=http://gta-analytics-gateway.internal:8000
# GATEWAY_IPC_MODE=unix
# USE_LITELLM=true
# (Set API keys via `fly secrets set`)
