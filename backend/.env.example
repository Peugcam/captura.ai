# =============================================================================
# GTA Analytics V2 - Environment Configuration Template
# =============================================================================
# SECURITY: Never commit the real .env file to version control!
# Copy this file to .env and replace placeholders with real values.
# =============================================================================

# Gateway Configuration
GATEWAY_URL=http://localhost:8000
POLL_INTERVAL=1.0
FRAMES_BATCH_SIZE=10

# OCR Configuration
OCR_ENABLED=true
OCR_WORKERS=4

# Game Configuration
# Options: gta, naruto
GAME_TYPE=gta
USE_ROI=false

# =============================================================================
# API Keys Configuration (SENSITIVE - DO NOT COMMIT)
# =============================================================================
# Multiple API keys can be configured for load balancing (comma-separated)
# Format: key1,key2,key3
#
# Supported providers:
# - OpenRouter: Keys start with sk-or-v1-
# - OpenAI: Keys start with sk-proj- or sk-
#
# Recommended order: OpenAI first (faster), OpenRouter second (fallback)
# =============================================================================
API_KEYS=your_openai_key_here,your_openrouter_key_here

# Vision Model Configuration
# OpenRouter format: openai/gpt-4o, anthropic/claude-3.5-sonnet, etc.
# OpenAI format: gpt-4o, gpt-4-vision-preview, etc.
VISION_MODEL=openai/gpt-4o

# Batch Processing Configuration
BATCH_SIZE_QUICK=3
BATCH_SIZE_DEEP=5
QUICK_BATCH_INTERVAL=0.5
DEEP_BATCH_INTERVAL=5.0

# Backend Server Configuration
BACKEND_PORT=3000
BACKEND_HOST=0.0.0.0

# Export Configuration
EXPORT_DIR=./exports

# Logging Configuration
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# =============================================================================
# Security Best Practices:
# =============================================================================
# 1. Never share your .env file
# 2. Use strong, unique API keys
# 3. Rotate API keys regularly (recommended: every 90 days)
# 4. Use different keys for development and production
# 5. Monitor API usage for anomalies
# 6. Keep this file permissions restricted (chmod 600 on Unix)
# =============================================================================
